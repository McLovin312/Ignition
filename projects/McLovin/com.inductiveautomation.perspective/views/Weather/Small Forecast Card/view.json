{
  "custom": {},
  "params": {
    "data": {
      "detailedForecast": "u\u0027detailedForecast\u0027",
      "endTime": "u\u0027endTime\u0027",
      "icon": "u\u0027icon\u0027",
      "isDaytime": "u\u0027isDaytime\u0027",
      "name": "u\u0027name\u0027",
      "number": "u\u0027number\u0027",
      "probabilityOfPrecipitation": {
        "unitCode": "wmoUnit:percent",
        "value": null
      },
      "shortForecast": "u\u0027shortForecast\u0027",
      "startTime": "u\u0027startTime\u0027",
      "temperature": 0,
      "temperatureTrend": "u\u0027temperatureTrend\u0027",
      "temperatureUnit": "u\u0027temperatureUnit\u0027",
      "windDirection": "u\u0027windDirection\u0027",
      "windSpeed": "u\u0027windSpeed\u0027"
    },
    "location": "value"
  },
  "propConfig": {
    "params.data": {
      "paramDirection": "input",
      "persistent": true
    },
    "params.location": {
      "paramDirection": "input",
      "persistent": true
    }
  },
  "props": {
    "defaultSize": {
      "height": 92,
      "width": 400
    }
  },
  "root": {
    "children": [
      {
        "meta": {
          "name": "Location"
        },
        "position": {
          "basis": "150px",
          "shrink": 0
        },
        "propConfig": {
          "props.text": {
            "binding": {
              "config": {
                "path": "view.params.location"
              },
              "type": "property"
            }
          }
        },
        "props": {
          "style": {
            "classes": "forecastHeader"
          }
        },
        "type": "ia.display.label"
      },
      {
        "children": [
          {
            "meta": {
              "name": "Temp"
            },
            "position": {
              "shrink": 0
            },
            "propConfig": {
              "props.text": {
                "binding": {
                  "config": {
                    "expression": "\"Current temp: \" + {view.params.data.temperature} + \"°\""
                  },
                  "type": "expr"
                }
              }
            },
            "props": {
              "style": {
                "classes": "forecast"
              }
            },
            "type": "ia.display.label"
          },
          {
            "meta": {
              "name": "Forecast"
            },
            "propConfig": {
              "props.text": {
                "binding": {
                  "config": {
                    "path": "view.params.data.detailedForecast"
                  },
                  "type": "property"
                }
              }
            },
            "props": {
              "style": {
                "classes": "forecast"
              }
            },
            "type": "ia.display.label"
          }
        ],
        "meta": {
          "name": "DataContainer"
        },
        "position": {
          "basis": "200px",
          "grow": 1
        },
        "props": {
          "alignContent": "flex-start",
          "alignItems": "flex-start",
          "direction": "column",
          "wrap": "wrap"
        },
        "type": "ia.container.flex"
      }
    ],
    "meta": {
      "name": "root"
    },
    "props": {
      "style": {
        "classes": "forecastCard"
      },
      "wrap": "wrap"
    },
    "type": "ia.container.flex"
  }
}